import sys
import json

def main() -> None:
    payload = json.loads(sys.stdin.read())
    fields = payload.get("fields", [])
    response = {
        "success": True,
        "fields": [
            {"name": f, "value": f"[dev placeholder — run python sidecar/build.py]", "confidence": 0.0}
            for f in fields
        ],
        "error": None,
    }
    print(json.dumps(response))

if __name__ == "__main__":
    main()
