# DocuScan Environment Variables
# Copy this file to .env and fill in values as needed.
# .env is gitignored — never commit secrets.

# HuggingFace API token (optional — improves rate limits for free tier)
# Get one at: https://huggingface.co/settings/tokens
HF_API_TOKEN=

# OpenAI API key (optional — only needed if user selects OpenAI provider)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API key (optional — only needed if user selects Gemini provider)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
